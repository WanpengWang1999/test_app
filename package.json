{
  "name": "telecom-photo-acceptance",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm.cmd run server:dev\" \"npm.cmd run client:dev\"",
    "server:dev": "node --watch server/index.js",
    "client:dev": "vite --host 0.0.0.0",
    "lan:dev": "concurrently \"npm.cmd run server:dev\" \"npm.cmd run client:dev\"",
    "build": "vite build",
    "start": "node server/index.js",
    "start:lan": "node server/index.js",
    "start:cloud": "bash scripts/start-cloud.sh",
    "android:add": "cap add android",
    "android:sync": "npm.cmd run build && cap sync android",
    "android:open": "cap open android",
    "android:apk": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-android-debug.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/network": "^8.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "archiver": "^7.0.1",
    "concurrently": "^9.1.2",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  }
}
