# Cloud deployment example.
# Copy this file to .env on the cloud server or export these variables in systemd.

NODE_ENV=production
HOST=127.0.0.1
PORT=3001

# Put data on a data disk in production, not inside the project directory.
DATA_DIR=/data/telecom-photo

# Public HTTPS address used by the web page diagnostics and Android App setup.
# Example: https://photo.example.com
PUBLIC_BASE_URL=https://your-domain.example.com

# Comma-separated allowed browser origins. Keep PUBLIC_BASE_URL here.
ALLOWED_ORIGINS=https://your-domain.example.com,capacitor://localhost,http://localhost

# Change this to a long random string before public testing.
AUTH_SECRET=change-this-to-a-long-random-secret
