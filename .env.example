# 本地/局域网部署配置示例
# 复制为 .env 后按实际环境修改。

# 后端监听地址和端口。0.0.0.0 表示允许局域网访问。
HOST=0.0.0.0
PORT=3001

# 允许访问后端的前端来源。
# 局域网测试可留空，系统默认允许 localhost、127.0.0.1、192.168.x.x、10.x.x.x、172.16-31.x.x。
ALLOWED_ORIGINS=

# 数据保存目录。默认是 server/data。
# 正式使用建议改到固定磁盘目录，例如 D:\telecom-photo-data 或 /data/telecom-photo。
DATA_DIR=server/data

# 网页/PWA 直接访问后端时使用。
# Android App 不依赖这里，首次打开 App 时在登录页填写服务器地址。
VITE_API_BASE_URL=
VITE_WS_BASE_URL=

# Vite 开发服务器代理到哪个后端。
VITE_DEV_API_TARGET=http://localhost:3001

# 生产环境请设置为一段足够长的随机字符串。
AUTH_SECRET=
