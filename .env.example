# 本地/局域网/云端部署配置示例
# 复制为 .env 后按实际环境修改。

# 后端监听地址和端口。
# 本地局域网调试可用 HOST=0.0.0.0；正式云端建议用 HOST=127.0.0.1，由 Nginx 反向代理。
HOST=0.0.0.0
PORT=3001

# 正式域名。正式部署建议使用 https://wangwanpeng.qzz.io。
# 局域网测试可留空。
PUBLIC_BASE_URL=

# 允许访问后端的前端来源。
# 正式部署建议：ALLOWED_ORIGINS=https://wangwanpeng.qzz.io,capacitor://localhost
# 局域网测试可留空，系统默认允许 localhost 和常见内网地址。
ALLOWED_ORIGINS=

# 数据保存目录。正式云端建议使用 /data/telecom-photo。
DATA_DIR=server/data

# 生产环境必须设置为足够长的随机字符串。
AUTH_SECRET=

# 正式初始完全管理员。仅首次创建该手机号账号时使用初始密码。
INITIAL_ADMIN_PHONE=19720410920
INITIAL_ADMIN_PASSWORD=WWP1999
INITIAL_ADMIN_NAME=正式管理员
INITIAL_ADMIN_COMPANY=

# 是否创建演示账号：admin/projectadmin/collector。
# 正式新部署保持 0；本地演示需要旧账号时可改成 1。
ENABLE_DEMO_USERS=0

# Android App 固定云端地址。以后更换域名并重打 APK 时修改这里。
VITE_FIXED_API_BASE_URL=https://wangwanpeng.qzz.io

# Web/PWA 直接访问后端时使用。正式同源部署可留空。
VITE_API_BASE_URL=
VITE_WS_BASE_URL=

# Vite 开发服务器代理目标。
VITE_DEV_API_TARGET=http://localhost:3001
